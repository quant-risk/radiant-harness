# AUR package for radiant-harness (Arch Linux / Manjaro / EndeavourOS).
#
# Submit to AUR:
#   git clone ssh://aur@aur.archlinux.org/radiant-harness.git
#   cp packaging/aur/PKGBUILD .
#   makepkg -si
#
# Maintainer: Henrique <henrique@fortvna.dev>

# Maintainer: Henrique <henrique@fortvna.dev>
pkgname=radiant-harness
pkgver=0.2.2
pkgrel=1
pkgdesc="Spec-Driven Development harness for AI coding agents — Go CLI with auto-correction loop and multi-LLM routing"
arch=('x86_64' 'aarch64')
url="https://github.com/Fortvna-Risk-Solutions/radiant-harness"
license=('MIT')
depends=()
makedepends=('go')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/Fortvna-Risk-Solutions/radiant-harness/releases/download/v${pkgver}/radiant_${pkgver}_${CARCH}.tar.gz")
sha256sums_x86_64=('REPLACE_WITH_LINUX_AMD64_SHA256')
sha256sums_aarch64=('REPLACE_WITH_LINUX_ARM64_SHA256')

package() {
    cd "${srcdir}"
    install -Dm755 "radiant" "${pkgdir}/usr/bin/radiant"
    install -Dm644 "LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" 2>/dev/null || true
}
