{
  "_comment": [
    "Cross-agent install/validation matrix used by `make test-agents`.",
    "Paths here MUST match the target paths cmd_setup_mcp.go writes to.",
    "If you add a new agent in hostdetect + setup-mcp, also add the matching",
    "row here. Keep `name` matching setup-mcp's --agent flag (which is the",
    "case label in cmd_setup_mcp.go::mcpConfigFor).",
    "",
    "For the modern (12-agent) list, see internal/hostdetect/hostdetect.go."
  ],
  "schema_version": 2,
  "agents": [
    {
      "name": "claude",
      "env": {
        "CLAUDE_CODE_ENTRY": "/Applications/Claude Code.app/.../claude-code",
        "CLAUDE_CODE_SSE_PORT": "12345",
        "CLAUDE_CODE_PID": "99999"
      },
      "config_file_relpath": ".claude/settings.json",
      "config_format": "json",
      "config_root_key": "mcpServers",
      "verify_keys": [
        ".claude.settings.json.mcpServers"
      ],
      "config_file_relpath_global": ".claude/settings.json",
      "config_file_relpath_project": ".claude/settings.json"
    },
    {
      "name": "cursor",
      "env": {
        "CURSOR_TRACE_ID": "abc123",
        "CURSOR_HOME": "/Applications/Cursor.app",
