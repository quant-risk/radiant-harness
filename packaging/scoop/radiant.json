# Scoop manifest for radiant-harness (Windows package manager).
#
# Install:
#   scoop bucket add fortvna https://github.com/Fortvna-Risk-Solutions/scoop-bucket
#   scoop install radiant
#
# Update VERSION and HASH below when releasing. Hash comes from
# `sha256sum radiant_0.2.2_windows_amd64.zip` after `goreleaser`.

{
    "version": "0.2.2",
    "description": "Spec-Driven Development harness for AI coding agents",
    "homepage": "https://github.com/Fortvna-Risk-Solutions/radiant-harness",
    "license": "MIT",
    "depends": "",
    "suggest": "",
    "bin": "radiant.exe",
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/Fortvna-Risk-Solutions/radiant-harness/releases/download/v$version/radiant_$version_windows_amd64.zip"
    },
    "url": "https://github.com/Fortvna-Risk-Solutions/radiant-harness/releases/download/v0.2.2/radiant_0.2.2_windows_amd64.zip",
    "hash": "REPLACE_WITH_WINDOWS_AMD64_SHA256",
    "extract_dir": "radiant_0.2.2_windows_amd64",
    "pre_install": [
        "# Add radiant to PATH for the current user via persistent env var",
        "[Environment]::SetEnvironmentVariable(\"Path\", $env:Path + \";$dir\", \"User\")"
    ],
    "post_install": [
        "# Show first-run hint about API keys.",
        "Write-Host 'radiant installed. Run `radiant doctor` to check your environment.'"
    ],
    "persist": []
}
